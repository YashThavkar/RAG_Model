OPENAI_API_KEY=sk-ijklmnop5678efghijklmnop5678efghijklmnop
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_CHAT_MODEL=gpt-4o-mini

# Embeddings (rebuild index after changing): default all-mpnet-base-v2
# EMBEDDING_MODEL_NAME=sentence-transformers/all-mpnet-base-v2

# Chunking (rebuild chunks + index after changing)
# CHUNK_TARGET_CHARS=1000
# CHUNK_OVERLAP_CHARS=200
# TOP_K=6
# SIMILARITY_THRESHOLD=0.0

# Hybrid retrieval: dense + BM25 (RRF), optional cross-encoder rerank
# USE_HYBRID_RETRIEVAL=1
# RRF_K=60
# HYBRID_CANDIDATE_POOL=48
# RERANK_WITH_CROSS_ENCODER=1
# RERANK_POOL_SIZE=24
# CROSS_ENCODER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# Ordered-token phrase match over the full corpus (short queries like "track, document")
# USE_LEXICAL_PHRASE_PRIORITY=1
# LEXICAL_PHRASE_MAX_SPAN=160
